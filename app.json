{
  "expo": {
    "name": "Velvet",
    "slug": "velvet",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "velvet",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourcompany.velvet",
      "associatedDomains": [
        "applinks:REPLACE_WITH_YOUR_DOMAIN"
      ]
    },
    "android": {
      "package": "com.yourcompany.velvet",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "androidStatusBar": {
        "barStyle": "light-content",
        "backgroundColor": "#0A0A0A",
        "translucent": true
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "velvet" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image",
      ["expo-splash-screen", {
        "backgroundColor": "#0A0A0A",
        "image": "./assets/splash-icon.png",
        "imageWidth": 200
      }],
      "expo-secure-store",
      "expo-localization",
      "expo-font",
      ["@sentry/react-native/expo", {
        "url": "https://sentry.io/",
        "project": "velvet",
        "organization": "REPLACE_WITH_YOUR_SENTRY_ORG"
      }],
      "@sentry/react-native",
      "expo-sharing"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "REPLACE_WITH_YOUR_EAS_PROJECT_ID"
      }
    },
    "owner": "REPLACE_WITH_YOUR_EXPO_OWNER"
  }
}
